# 环境变量模板 — 复制为 .env 后填入真实值
# 所有变量前缀 SL_

# 登录密码（必填）
SL_PASSWORD=你的密码

# JWT 密钥（留空自动生成，但重启后所有 token 失效）
# SL_SECRET_KEY=随机字符串

# 币安 API
# SL_BINANCE_API_KEY=你的key
# SL_BINANCE_API_SECRET=你的secret
# SL_BINANCE_TESTNET=false
# SL_BINANCE_PROXY=http://127.0.0.1:7890

# 止损
# SL_STOP_LOSS_THRESHOLD=5
# SL_THRESHOLD_TYPE=percent
# SL_CHECK_INTERVAL_SECONDS=5
# SL_DRY_RUN=true

# 服务器
# SL_HOST=0.0.0.0
# SL_PORT=8080
